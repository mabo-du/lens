# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent and tooling artifacts
# Note: .claude/skills/ is re-included below; project-level Claude SKILL.md
# files are peer-published tooling and belong in the open-source repo.
*.charter-session
.charter/
.agents/
.beads/
.claude/*
!.claude/skills/
.claude/local/
.ctx/
.gitnexus/
.windsurf/
.aidevops.json

# Cursor / Windsurf caches
.cursor/cache/
.hk/

# Rust build targets
/target/
/src-tauri/target/

# Root Cargo.lock (no root Cargo.toml — Tauri Cargo.toml is in src-tauri/)
Cargo.lock

# Temporary commit message drafts
.commitmsg*
.commit_*.txt

# GitHub admin notes — one-off setup doc that is DELIBERATELY force-tracked.
# `.gh_admin_org_setup.md` is the org-blocklist lift procedure that future
# maintainers need BEFORE they can unblock the v0.2.x release matrix. The
# negation below carves it back in so `git ls-files` finds it. Do not
# re-ignore without updating `.gh_admin_org_setup.md` cross-refs
# (README, USER_GUIDE, CHANGELOG).
.gh_admin_org_setup.md
!.gh_admin_org_setup.md

# Charter analysis artefacts
charter-report.json

# One-off utility scripts
navigate.cjs

# PyInstaller + sidecar build artefacts
# (the canonical Linux-side pdfplumber bundle is built per-platform
#  by scripts/build-sidecar.sh, not committed)
/src-tauri/sidecars/*-*
/src-tauri/sidecars/*/build/
/src-tauri/sidecars/*/dist/
/src-tauri/sidecars/*/.venv/
*.pyz
*.spec
base_library.zip

# Backup files
*~
*.bak
*.orig
*.rej

# Environment and secrets
.env*
!.env.example

# ---- Playwright + CI artifacts ----
# Generated on every Playwright run via globalSetup/globalTeardown
# (see tests/e2e/global-setup.mjs). Recreate locally with
# `npx playwright test --config=tests/e2e/playwright.config.ts`.
playwright-report/
test-results/
.lens-e2e/

# Playwright MCP server ephemeral state (used outside CI during dev).
.playwright-mcp/

# Python build + test artifacts (added at v0.2.1 to keep python/tests/ tracked while ignoring pyc + caches)
__pycache__/
*.pyc
*.pyo
.python-version
.pytest_cache/
*.egg-info/
.python-venv/
# modern PEP 660 editable-install pattern (setuptools >=64)
__editable__/
