{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LENS",
  "version": "0.1.0",
  "identifier": "org.heritagetech.lens",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:57598",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LENS",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "sidecars/pdfplumber/pdfplumber"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/mabo-du/lens/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBODgzQ0U5MDE1MjQ0M0QKUldROVJGSUI2VHlJMmt6Q3VLNWVnT2ZCalRWcE1nSkcvVnRDK0Q1NyszTlN3RkdHN1FHTmhUMGIK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
