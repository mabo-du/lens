# =========================================================================
# Release Secrets (DO NOT COMMIT ACTUAL VALUES)
# =========================================================================
#
# These variables are consumed by `.github/workflows/release.yml` via
# `secrets.*` references; they are NOT read by the application at
# runtime. They exist at GitHub-Actions-time and are injected by the
# runner. The actual values live in the repo's
# `Settings -> Secrets and variables -> Actions` page.
#
# To rotate or generate any of these, see `AGENTS.md -> Release Secrets`.
# =========================================================================

# -----------------------------------------------------------------------------
# Tauri code-signing key pair (`tauri signer generate`)
# -----------------------------------------------------------------------------
# Generate ONCE on a developer machine:
#
#   cargo install tauri-cli --version "^2"
#   cd src-tauri && tauri signer generate -w ~/.tauri/lens.key
#
# The CLI prompts for a password and writes two files:
#   - ~/.tauri/lens.key              (KEEP OFFLINE: the private key)
#   - ~/.tauri/lens.key.pub          (paste into `bundle.updater.pubkey`)
#
# Add to GitHub Secrets:
#   TAURI_SIGNING_PRIVATE_KEY          contents of ~/.tauri/lens.key
#   TAURI_SIGNING_PRIVATE_KEY_PASSWORD the password used above
#
# Newly generated keys MUST update `bundle.updater.pubkey` in
# `src-tauri/tauri.conf.json` (the `pubkey` field is the PUBLIC half of
# the pair; committing the public key is fine, the private key must
# remain offline except when pasted into GitHub Secrets).
# -----------------------------------------------------------------------------
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# -----------------------------------------------------------------------------
# macOS notarization (Apple Developer Program)
# -----------------------------------------------------------------------------
# Add to GitHub Secrets:
#   APPLE_CERTIFICATE              base64 of DeveloperIDApplication.p12
#   APPLE_CERTIFICATE_PASSWORD     the .p12 export password
#   APPLE_ID                       Apple ID email
#   APPLE_PASSWORD                 app-specific password (NOT your Apple ID password)
#   APPLE_TEAM_ID                  10-character team identifier (Developer Portal)
# -----------------------------------------------------------------------------
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=

# -----------------------------------------------------------------------------
# Optional per-developer local overrides
# -----------------------------------------------------------------------------
# Copy this file to `.env` (git-ignored) for personal overrides. Anything
# in `.env` is loaded by `vite dev` automatically; it should NOT reference
# release-time secrets (those belong in GitHub Secrets only).
# -----------------------------------------------------------------------------
# DEV_LOG_LEVEL=debug
