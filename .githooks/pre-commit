#!/usr/bin/env bash
# Pre-commit hook.
#
#   1. npx tsc --noEmit
#   2. cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --features sqlcipher -- -D warnings
#   3. cargo test --features sqlcipher
#
# (charter doctor and aislop scan are no longer wired in this hook — see
# commit removing them following the maintainer's choice to opt out.)

set -euo pipefail
echo "[pre-commit] running gates..."

echo "[pre-commit] 1/3 TypeScript: npx tsc --noEmit"
npx tsc --noEmit

echo "[pre-commit] 2/3 Rust:    cargo clippy -D warnings (sqlcipher)"
# Clippy BEFORE cargo test so a lint regression fails fast (no need
# to run the full test wall-clock for an easy-to-detect signal). The
# `-D warnings` flag matches the CI gate so local devs hit the same
# wall a PR would. Run clippy with `--features sqlcipher` to mirror
# the next step's feature flag — otherwise #[cfg(feature = "sqlcipher")]
# code paths never lint locally and pre-commit green ≠ CI green.
cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --features sqlcipher -- -D warnings

echo "[pre-commit] 3/3 Rust:    cargo test  (sqlcipher feature)"
(cd src-tauri && cargo test --features sqlcipher)

echo "[pre-commit] OK"
